{
  "name": "gram-panchayat-management",
  "version": "1.0.0",
  "description": "A comprehensive management system for gram panchayats",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "dev:backend": "cd backend && npm run dev",
    "dev:full": "concurrently \"npm run dev:backend\" \"npm run dev\"",
    "install:backend": "cd backend && npm install",
    "setup": "npm install && npm run install:backend"
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "lucide-react": "^0.292.0",
    "puppeteer": "^24.43.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.40",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "typescript": "^5.9.3",
    "vite": "^5.0.8"
  }
}
